# DeepSeek API (OpenAI-compatible). Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_TOOLS=deepseek-chat
DEEPSEEK_MODEL_REASON=deepseek-reasoner

# Retrieval (local models; first run downloads ~150MB)
EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base
ENABLE_DENSE_RETRIEVAL=true     # false = BM25-only (no model download, instant)

# OCR (optional; needs system Tesseract installed)
ENABLE_OCR=false
